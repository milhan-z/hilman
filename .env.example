# ── Supabase ──────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by `npm run seed` and never shipped to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudinary ────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Server-only. Used by /api/cloudinary/sign for signed uploads.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Site ──────────────────────────────────────────────────
# e.g. https://hilman.vercel.app (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
